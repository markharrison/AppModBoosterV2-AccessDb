@using WebApp.Models
@model InvoiceDto
@{
    ViewData["Title"] = "Invoice - Order #" + Model.OrderId;
    Layout = "_InvoiceLayout";
}

<div class="nw-invoice">
    <div class="invoice-header">
        <div class="company-info">
            <h1 class="company-name">Northwind Traders</h1>
            <div class="company-tagline">Invoice</div>
        </div>
        <div class="invoice-meta">
            <table>
                <tr><th>Invoice #</th><td>@Model.OrderId</td></tr>
                <tr><th>Order Date</th><td>@Model.OrderDate?.ToString("MMMM d, yyyy")</td></tr>
                <tr><th>Salesperson</th><td>@Model.EmployeeFullName</td></tr>
                <tr><th>Status</th><td>@Model.StatusName</td></tr>
            </table>
        </div>
    </div>

    <div class="bill-to">
        <strong>Bill To:</strong><br />
        @Model.CustomerName<br />
        @if (!string.IsNullOrWhiteSpace(Model.CustomerAddress)) { @Model.CustomerAddress; <br /> }
        @if (!string.IsNullOrWhiteSpace(Model.CustomerCity) || !string.IsNullOrWhiteSpace(Model.CustomerState)) {
            @($"{Model.CustomerCity}, {Model.CustomerState} {Model.CustomerZip}".Trim()); <br />
        }
    </div>

    <table class="invoice-table">
        <thead>
            <tr>
                <th>Code</th>
                <th>Product</th>
                <th class="text-end">Qty</th>
                <th class="text-end">Unit Price</th>
                <th class="text-end">Extended</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var line in Model.LineItems)
            {
                <tr>
                    <td>@line.ProductCode</td>
                    <td>@line.ProductName</td>
                    <td class="text-end">@line.Quantity</td>
                    <td class="text-end">$@line.UnitPrice.ToString("N2")</td>
                    <td class="text-end">$@line.ExtendedPrice.ToString("N2")</td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr class="total-row">
                <td colspan="4" class="text-end"><strong>Order Total</strong></td>
                <td class="text-end"><strong>$@Model.OrderTotal.ToString("N2")</strong></td>
            </tr>
        </tfoot>
    </table>

    <div class="invoice-footer nw-no-print mt-3">
        <button class="btn btn-outline-primary" onclick="window.print()">
            <i class="bi bi-printer me-1"></i>Print Invoice
        </button>
        <a asp-controller="Orders" asp-action="Detail" asp-route-id="@Model.OrderId" class="btn btn-outline-secondary ms-2">
            <i class="bi bi-arrow-left me-1"></i>Back to Order
        </a>
    </div>
</div>
