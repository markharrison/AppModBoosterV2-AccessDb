@using WebApp.Models
@model OrderRequest
@{
    ViewData["Title"] = "New Order";
    var customers = (ViewBag.Customers as List<CustomerLookupDto>) ?? [];
    var employees = (ViewBag.Employees as List<EmployeeLookupDto>) ?? [];
    var statuses = (ViewBag.Statuses as List<OrderStatusDto>) ?? [];
}

<div class="nw-page-header">
    <h1><i class="bi bi-cart-plus me-2"></i>New Order</h1>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="card" style="max-width:640px">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Customer</label>
                    <select name="CustomerId" class="form-select">
                        <option value="">-- Select Customer --</option>
                        @foreach (var c in customers)
                        {
                            <option value="@c.CustomerId">@c.CustomerName</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Salesperson</label>
                    <select name="EmployeeId" class="form-select">
                        <option value="">-- Select Employee --</option>
                        @foreach (var e in employees)
                        {
                            <option value="@e.EmployeeId">@e.FullNameFNLN</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Status</label>
                    <select name="StatusId" class="form-select">
                        @foreach (var s in statuses)
                        {
                            if (s.StatusName == "New")
                            {
                                <option value="@s.StatusId" selected>@s.StatusName</option>
                            }
                            else
                            {
                                <option value="@s.StatusId">@s.StatusName</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Order Date</label>
                    <input type="date" name="OrderDate" class="form-control"
                           value="@Model.OrderDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-12">
                    <label class="form-label">Notes</label>
                    <textarea name="Notes" class="form-control" rows="3"></textarea>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Create Order</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
<p class="text-muted mt-2 small"><i class="bi bi-info-circle me-1"></i>Line items can be added after the order is
    created.</p>