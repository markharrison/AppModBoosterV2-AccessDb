@using WebApp.Models
@model OrderDetail
@{
    ViewData["Title"] = $"Order #{Model?.Id}";
    var customers = ViewBag.Customers as List<LookupCustomer> ?? new();
    var employees = ViewBag.Employees as List<LookupEmployee> ?? new();
    var statuses = ViewBag.Statuses as List<LookupOrderStatus> ?? new();
    var products = ViewBag.Products as List<LookupProduct> ?? new();
    var recentOrders = ViewBag.RecentOrders as List<OrderListItem> ?? new();
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Orders</a></li>
        <li class="breadcrumb-item active">Order #@Model?.Id</li>
    </ol>
</nav>

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="page-heading"><i class="bi bi-receipt me-2"></i>Order #@Model?.Id</h1>
    <div class="d-flex gap-2 no-print">
        <a asp-controller="Reports" asp-action="Invoice" asp-route-orderId="@Model?.Id" target="_blank" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-printer me-1"></i>Invoice
        </a>
        <form asp-action="Delete" asp-route-id="@Model?.Id" method="post"
              onsubmit="return confirm('Delete this order and all line items?')">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-outline-danger">Delete Order</button>
        </form>
    </div>
</div>

<div class="row g-3">
    <!-- Order Header -->
    <div class="col-12 col-lg-8">
        <div class="card mb-3">
            <div class="card-header">Order Details</div>
            <div class="card-body">
                <form asp-action="Detail" asp-route-id="@Model?.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Customer</label>
                            <select name="CustomerId" class="form-select">
                                <option value="">--</option>
                                @foreach (var c in customers)
                                {
                                    <option value="@c.Id" selected="@(Model?.CustomerId == c.Id ? "selected" : null)">@c.CustomerName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Employee</label>
                            <select name="EmployeeId" class="form-select">
                                <option value="">--</option>
                                @foreach (var e in employees)
                                {
                                    <option value="@e.Id" selected="@(Model?.EmployeeId == e.Id ? "selected" : null)">@e.FullNameFNLN</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Order Date</label>
                            <input type="date" name="OrderDate" value="@Model?.OrderDate?.ToString("yyyy-MM-dd")" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Shipped Date</label>
                            <input type="date" name="ShippedDate" value="@Model?.ShippedDate?.ToString("yyyy-MM-dd")" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Paid Date</label>
                            <input type="date" name="PaidDate" value="@Model?.PaidDate?.ToString("yyyy-MM-dd")" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Notes</label>
                            <textarea name="Notes" class="form-control" rows="2">@Model?.Notes</textarea>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-3 align-items-center">
                        <button type="submit" class="btn btn-primary btn-sm">Save Header</button>
                        <span class="ms-3 text-muted small">Status:</span>
                    </div>
                </form>

                <!-- Quick status update -->
                <form asp-action="UpdateStatus" asp-route-id="@Model?.Id" method="post" class="d-flex gap-2 mt-2 align-items-center">
                    @Html.AntiForgeryToken()
                    <select name="status" class="form-select form-select-sm" style="max-width:180px">
                        @foreach (var s in statuses)
                        {
                            <option value="@s.Value" selected="@(Model?.Status == s.Value ? "selected" : null)">@s.Display</option>
                        }
                    </select>
                    <button type="submit" class="btn btn-sm btn-outline-primary">Update Status</button>
                    @{ var sc = "badge-status-" + (Model?.Status ?? "").ToLower(); }
                    <span class="badge @sc ms-1">@Model?.StatusDisplay</span>
                </form>
            </div>
        </div>

        <!-- Line Items -->
        <div class="card">
            <div class="card-header">Line Items</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th class="text-end">Qty</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end">Extended</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in Model?.OrderDetails ?? new())
                            {
                                <tr>
                                    <td>@line.ProductName <small class="text-muted">(@line.ProductCode)</small></td>
                                    <td class="text-end">@line.Quantity</td>
                                    <td class="text-end">@line.UnitPrice.ToString("C")</td>
                                    <td class="text-end">@line.ExtendedPrice.ToString("C")</td>
                                    <td class="text-end">
                                        <form asp-action="DeleteLine" asp-route-id="@Model?.Id" asp-route-lineId="@line.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-xs btn-outline-danger btn-sm py-0 px-1" title="Remove">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                            @if (!(Model?.OrderDetails?.Any() ?? false))
                            {
                                <tr><td colspan="5" class="text-center text-muted py-2">No line items.</td></tr>
                            }
                        </tbody>
                        <tfoot class="table-light fw-semibold">
                            <tr>
                                <td colspan="3" class="text-end">Order Total</td>
                                <td class="text-end" id="orderTotal">@(Model?.OrderTotal.ToString("C"))</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <!-- Add Line Item -->
                <div class="p-3 border-top">
                    <h6 class="fw-semibold mb-2">Add Line Item</h6>
                    <form asp-action="AddLine" asp-route-id="@Model?.Id" method="post" class="row g-2 align-items-end">
                        @Html.AntiForgeryToken()
                        <div class="col-sm-5">
                            <label class="form-label small">Product</label>
                            <select id="lineProductId" name="productId" class="form-select form-select-sm" required>
                                <option value="">-- Select --</option>
                                @foreach (var p in products)
                                {
                                    <option value="@p.Id" data-price="@p.UnitPrice">@p.ProductName (@p.ProductCode)</option>
                                }
                            </select>
                        </div>
                        <div class="col-sm-2">
                            <label class="form-label small">Qty</label>
                            <input type="number" id="lineQty" name="quantity" class="form-control form-control-sm" min="1" value="1" required />
                        </div>
                        <div class="col-sm-3">
                            <label class="form-label small">Unit Price &nbsp;<span class="text-muted">=&nbsp;<span id="lineTotal">0.00</span></span></label>
                            <input type="number" id="lineUnitPrice" name="unitPrice" step="0.01" class="form-control form-control-sm" min="0" value="0.00" required />
                        </div>
                        <div class="col-sm-2">
                            <button type="submit" class="btn btn-sm btn-success w-100">Add</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Side panel: recent orders for same customer -->
    <div class="col-12 col-lg-4">
        <div class="card side-panel">
            <div class="card-header"><i class="bi bi-clock-history me-1"></i>Recent Orders (Same Customer)</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>#</th><th>Date</th><th>Status</th><th class="text-end">Total</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var ro in recentOrders)
                            {
                                var rsc = "badge-status-" + (ro.Status ?? "").ToLower();
                                <tr data-href="/Orders/Detail/@ro.Id">
                                    <td><a asp-action="Detail" asp-route-id="@ro.Id">#@ro.Id</a></td>
                                    <td>@ro.OrderDate?.ToString("MM/dd/yy")</td>
                                    <td><span class="badge @rsc">@ro.StatusDisplay</span></td>
                                    <td class="text-end">@ro.OrderTotal.ToString("C")</td>
                                </tr>
                            }
                            @if (!recentOrders.Any())
                            {
                                <tr><td colspan="4" class="text-center text-muted py-2">No other orders.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
