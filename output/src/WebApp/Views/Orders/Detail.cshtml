@using WebApp.Models
@model OrderFullDto
@{
    ViewData["Title"] = "Order #" + Model.OrderId;
    var customers = (ViewBag.Customers as List<CustomerLookupDto>) ?? [];
    var employees = (ViewBag.Employees as List<EmployeeLookupDto>) ?? [];
    var statuses = (ViewBag.Statuses as List<OrderStatusDto>) ?? [];
    var products = (ViewBag.Products as List<ProductLookupDto>) ?? [];
}

<div class="nw-page-header">
    <h1><i class="bi bi-receipt me-2"></i>Order #@Model.OrderId</h1>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
        <a asp-action="Invoice" asp-route-id="@Model.OrderId" class="btn btn-outline-info" target="_blank">
            <i class="bi bi-printer me-1"></i>Print Invoice
        </a>
        <form asp-action="Delete" asp-route-id="@Model.OrderId" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger"
                    data-confirm="Delete this order and all its line items?">
                <i class="bi bi-trash me-1"></i>Delete
            </button>
        </form>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">Order Details</div>
            <div class="card-body">
                <form asp-action="Detail" asp-route-id="@Model.OrderId" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Customer</label>
                            <select name="CustomerId" class="form-select">
                                <option value="">-- None --</option>
                                @foreach (var c in customers)
                                {
                                    if (Model.CustomerId == c.CustomerId)
                                    {
                                        <option value="@c.CustomerId" selected>@c.CustomerName</option>
                                    }
                                    else
                                    {
                                        <option value="@c.CustomerId">@c.CustomerName</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Salesperson</label>
                            <select name="EmployeeId" class="form-select">
                                <option value="">-- None --</option>
                                @foreach (var e in employees)
                                {
                                    if (Model.EmployeeId == e.EmployeeId)
                                    {
                                        <option value="@e.EmployeeId" selected>@e.FullNameFNLN</option>
                                    }
                                    else
                                    {
                                        <option value="@e.EmployeeId">@e.FullNameFNLN</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Status</label>
                            <select name="StatusId" class="form-select">
                                @foreach (var s in statuses)
                                {
                                    if (Model.StatusId == s.StatusId)
                                    {
                                        <option value="@s.StatusId" selected>@s.StatusName</option>
                                    }
                                    else
                                    {
                                        <option value="@s.StatusId">@s.StatusName</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Order Date</label>
                            <input type="date" name="OrderDate" class="form-control"
                                   value="@Model.OrderDate?.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Shipped Date</label>
                            <input type="date" name="ShippedDate" class="form-control"
                                   value="@Model.ShippedDate?.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Paid Date</label>
                            <input type="date" name="PaidDate" class="form-control"
                                   value="@Model.PaidDate?.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Notes</label>
                            <textarea name="Notes" class="form-control" rows="2">@Model.Notes</textarea>
                        </div>
                    </div>
                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save
                            Order</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card h-100">
                <div class="card-header">Order Summary</div>
                <div class="card-body d-flex flex-column justify-content-center align-items-center text-center">
                    <div class="stat-label">Order Total</div>
                    <div class="stat-value" id="orderTotal">$@Model.OrderTotal.ToString("N2")</div>
                    <div class="text-muted small mt-2">@Model.OrderDetails.Count line items</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Hidden update/delete forms for line items (HTML5 form association) -->
    @foreach (var line in Model.OrderDetails)
    {
        <form id="update-form-@line.OrderDetailId" asp-action="UpdateDetail" asp-route-id="@Model.OrderId"
              asp-route-detailId="@line.OrderDetailId" method="post" style="display:none">
            @Html.AntiForgeryToken()
        </form>
        <form id="delete-form-@line.OrderDetailId" asp-action="DeleteDetail" asp-route-id="@Model.OrderId"
              asp-route-detailId="@line.OrderDetailId" method="post" style="display:none">
            @Html.AntiForgeryToken()
        </form>
    }

    <!-- Line Items -->
    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between">
            <span><i class="bi bi-list-ul me-2"></i>Line Items</span>
        </div>
        <div class="card-body p-0">
            @if (Model.OrderDetails.Count == 0)
            {
                <div class="nw-empty"><i class="bi bi-inbox"></i>No line items yet.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th style="width:35%">Product</th>
                                <th class="text-end" style="width:12%">Qty</th>
                                <th class="text-end" style="width:15%">Unit Price</th>
                                <th class="text-end" style="width:15%">Extended</th>
                                <th style="width:23%"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in Model.OrderDetails)
                            {
                                <tr class="nw-line-row">
                                    <td>
                                        <select name="ProductId" form="update-form-@line.OrderDetailId"
                                                class="form-select form-select-sm nw-product-select">
                                            @foreach (var p in products)
                                            {
                                                if (line.ProductId == p.ProductId)
                                                {
                                                    <option value="@p.ProductId" data-price="@p.UnitPrice" selected>@p.ProductName</option>
                                                }
                                                else
                                                {
                                                    <option value="@p.ProductId" data-price="@p.UnitPrice">@p.ProductName</option>
                                                }
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        <input type="number" name="Quantity" form="update-form-@line.OrderDetailId"
                                               value="@line.Quantity" min="1"
                                               class="form-control form-control-sm text-end nw-qty-input"
                                               style="width:80px;margin-left:auto" />
                                    </td>
                                    <td>
                                        <input type="number" name="UnitPrice" form="update-form-@line.OrderDetailId"
                                               value="@line.UnitPrice" step="0.01" min="0"
                                               class="form-control form-control-sm text-end nw-unit-price"
                                               style="width:100px;margin-left:auto" />
                                    </td>
                                    <td class="text-end align-middle">
                                        <span
                                        class="nw-extended-price nw-line-extended-val">$@line.ExtendedPrice.ToString("N2")</span>
                                    </td>
                                    <td class="text-end">
                                        <button type="submit" form="update-form-@line.OrderDetailId"
                                                class="btn btn-sm btn-outline-primary me-1">Save</button>
                                        <button type="submit" form="delete-form-@line.OrderDetailId"
                                                class="btn btn-sm btn-outline-danger" data-confirm="Remove this line item?">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
        <div class="card-footer">
            <strong class="small text-muted">Add Line Item</strong>
            <form asp-action="AddDetail" asp-route-id="@Model.OrderId" method="post"
                  class="d-flex gap-2 flex-wrap mt-2 align-items-end nw-line-row">
                @Html.AntiForgeryToken()
                <div>
                    <label class="form-label">Product</label>
                    <select name="ProductId" class="form-select form-select-sm nw-product-select" style="min-width:200px">
                        <option value="">-- Select --</option>
                        @foreach (var p in products)
                        {
                            <option value="@p.ProductId" data-price="@p.UnitPrice">@p.ProductName (@p.ProductCode)</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label">Qty</label>
                    <input type="number" name="Quantity" value="1" min="1" class="form-control form-control-sm nw-qty-input"
                           style="width:75px" />
                </div>
                <div>
                    <label class="form-label">Unit Price</label>
                    <input type="number" name="UnitPrice" value="0" step="0.01" min="0"
                           class="form-control form-control-sm nw-unit-price" style="width:100px" />
                </div>
                <div>
                    <label class="form-label">Extended</label>
                    <div class="form-control-plaintext small fw-semibold nw-extended-price">$0.00</div>
                </div>
                <div>
                    <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-plus-lg me-1"></i>Add</button>
                </div>
            </form>
        </div>
    </div>
