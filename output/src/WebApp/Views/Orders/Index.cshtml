@using WebApp.Models
@model List<OrderSummaryDto>
@{
    ViewData["Title"] = "Orders";
    var customers = (ViewBag.Customers as List<CustomerLookupDto>) ?? [];
    var employees = (ViewBag.Employees as List<EmployeeLookupDto>) ?? [];
    var statuses = (ViewBag.Statuses as List<OrderStatusDto>) ?? [];
    int? filterCustomerId = ViewBag.FilterCustomerId;
    int? filterEmployeeId = ViewBag.FilterEmployeeId;
    int? filterStatusId = ViewBag.FilterStatusId;
    string? filterDate = ViewBag.FilterOrderDate as string;
}

<div class="nw-page-header">
    <h1><i class="bi bi-cart3 me-2"></i>Orders</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>New Order</a>
</div>

<div class="nw-filter-bar">
    <form method="get" class="row g-2 align-items-end">
        <div class="col-sm-6 col-md-3">
            <label class="form-label">Customer</label>
            <select name="customerId" class="form-select">
                <option value="">All Customers</option>
                @foreach (var c in customers)
                {
                    if (filterCustomerId == c.CustomerId)
                    {
                        <option value="@c.CustomerId" selected>@c.CustomerName</option>
                    }
                    else
                    {
                        <option value="@c.CustomerId">@c.CustomerName</option>
                    }
                }
            </select>
        </div>
        <div class="col-sm-6 col-md-3">
            <label class="form-label">Salesperson</label>
            <select name="employeeId" class="form-select">
                <option value="">All Employees</option>
                @foreach (var e in employees)
                {
                    if (filterEmployeeId == e.EmployeeId)
                    {
                        <option value="@e.EmployeeId" selected>@e.FullNameFNLN</option>
                    }
                    else
                    {
                        <option value="@e.EmployeeId">@e.FullNameFNLN</option>
                    }
                }
            </select>
        </div>
        <div class="col-sm-6 col-md-2">
            <label class="form-label">Status</label>
            <select name="statusId" class="form-select">
                <option value="">All Statuses</option>
                @foreach (var s in statuses)
                {
                    if (filterStatusId == s.StatusId)
                    {
                        <option value="@s.StatusId" selected>@s.StatusName</option>
                    }
                    else
                    {
                        <option value="@s.StatusId">@s.StatusName</option>
                    }
                }
            </select>
        </div>
        <div class="col-sm-6 col-md-2">
            <label class="form-label">Order Date</label>
            <input type="date" name="orderDate" value="@filterDate" class="form-control" />
        </div>
        <div class="col-auto d-flex gap-2">
            <button type="submit" class="btn btn-outline-primary"><i class="bi bi-funnel me-1"></i>Filter</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    </form>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Count == 0)
        {
            <div class="nw-empty"><i class="bi bi-inbox"></i>No orders found.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Date</th>
                            <th>Customer</th>
                            <th>Salesperson</th>
                            <th>Status</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model)
                        {
                            <tr>
                                <td><a asp-action="Detail" asp-route-id="@o.OrderId">#@o.OrderId</a></td>
                                <td>@o.OrderDate?.ToString("MM/dd/yyyy")</td>
                                <td>@o.CustomerName</td>
                                <td>@o.EmployeeFullName</td>
                                <td><span class="badge @GetStatusClass(o.StatusName)">@o.StatusName</span></td>
                                <td class="text-end fw-semibold">$@o.OrderTotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@functions {
    string GetStatusClass(string? name) => (name ?? "").ToLower() switch
    {
        "new" => "status-new",
        "invoiced" => "status-invoiced",
        "shipped" => "status-shipped",
        "closed" => "status-closed",
        "cancelled" => "status-cancelled",
        _ => "bg-secondary"
    };
}
