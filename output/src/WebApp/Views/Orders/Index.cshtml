@using WebApp.Models
@model PagedResult<OrderListItem>?
@{
    ViewData["Title"] = "Orders";
    var customers = ViewBag.Customers as List<LookupCustomer> ?? new();
    var employees = ViewBag.Employees as List<LookupEmployee> ?? new();
    var statuses = ViewBag.Statuses as List<LookupOrderStatus> ?? new();
    int? custFilter = ViewBag.CustomerIdFilter;
    int? empFilter = ViewBag.EmployeeIdFilter;
    string? statusFilter = ViewBag.StatusFilter;
    string? sortBy = ViewBag.SortBy;
    var currentPage = Model?.Page ?? 1;
    var totalPages = Model?.TotalPages ?? 1;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item active">Orders</li>
    </ol>
</nav>

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="page-heading"><i class="bi bi-cart3 me-2"></i>Orders</h1>
    <a asp-action="New" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>New Order</a>
</div>

<!-- Filters -->
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-3">
                <label class="form-label small">Customer</label>
                <select name="customerId" class="form-select form-select-sm">
                    <option value="">All Customers</option>
                    @foreach (var c in customers)
                    {
                        <option value="@c.Id" selected="@(custFilter == c.Id ? "selected" : null)">@c.CustomerName</option>
                    }
                </select>
            </div>
            <div class="col-sm-3">
                <label class="form-label small">Employee</label>
                <select name="employeeId" class="form-select form-select-sm">
                    <option value="">All Employees</option>
                    @foreach (var e in employees)
                    {
                        <option value="@e.Id" selected="@(empFilter == e.Id ? "selected" : null)">@e.FullNameFNLN</option>
                    }
                </select>
            </div>
            <div class="col-sm-2">
                <label class="form-label small">Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">All</option>
                    @foreach (var s in statuses)
                    {
                        <option value="@s.Value" selected="@(statusFilter == s.Value ? "selected" : null)">@s.Display</option>
                    }
                </select>
            </div>
            <div class="col-sm-2">
                <label class="form-label small">Sort By</label>
                <select name="sortBy" class="form-select form-select-sm">
                    <option value="orderDate" selected="@(sortBy == "orderDate" || string.IsNullOrEmpty(sortBy) ? "selected" : null)">Order Date</option>
                    <option value="modifiedOn" selected="@(sortBy == "modifiedOn" ? "selected" : null)">Last Modified</option>
                </select>
            </div>
            <div class="col-sm-2">
                <button type="submit" class="btn btn-sm btn-outline-primary w-100">Filter</button>
            </div>
            <div class="col-sm-12">
                <a asp-action="Index" class="btn btn-sm btn-link ps-0">Clear Filters</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Order #</th>
                        <th>Order Date</th>
                        <th>Customer</th>
                        <th>Employee</th>
                        <th>Status</th>
                        <th class="text-end">Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model?.Items ?? new())
                    {
                        var sc = "badge-status-" + (o.Status ?? "").ToLower();
                        <tr data-href="/Orders/Detail/@o.Id">
                            <td><a asp-action="Detail" asp-route-id="@o.Id">#@o.Id</a></td>
                            <td>@o.OrderDate?.ToString("MM/dd/yyyy")</td>
                            <td>@(o.CustomerName ?? "-")</td>
                            <td>@(o.EmployeeFullName ?? "-")</td>
                            <td><span class="badge @sc">@o.StatusDisplay</span></td>
                            <td class="text-end">@o.OrderTotal.ToString("C")</td>
                        </tr>
                    }
                    @if (!(Model?.Items?.Any() ?? false))
                    {
                        <tr><td colspan="6" class="text-center text-muted py-3">No orders found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (var i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-customerId="@custFilter" asp-route-employeeId="@empFilter"
                       asp-route-status="@statusFilter" asp-route-sortBy="@sortBy" asp-route-page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}
