@using WebApp.Models
@{
    ViewData["Title"] = "Dashboard";
    var ytd = ViewBag.YtdSales as SalesYtd;
    var salesByEmp = ViewBag.SalesByEmployee as List<SalesByEmployee> ?? new();
    var recentOrders = ViewBag.RecentOrders as List<OrderListItem> ?? new();
    var topProducts = ViewBag.TopProducts as List<ProductListItem> ?? new();

    // Pivot: employee -> total YTD
    var empTotals = salesByEmp.GroupBy(x => x.EmployeeFullName)
        .Select(g => new { Name = g.Key, Total = g.Sum(x => x.TotalSales) })
        .OrderByDescending(x => x.Total).ToList();
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item active">Dashboard</li>
    </ol>
</nav>

<div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="page-heading"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h1>
</div>

<!-- YTD Stat Card -->
<div class="row g-3 mb-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card stat-card p-3">
            <div class="stat-label">YTD Revenue</div>
            <div class="stat-value">@((ytd?.TotalSales ?? 0).ToString("C"))</div>
            <div class="small opacity-75 mt-1">as of @DateTime.Now.Year</div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card stat-card p-3">
            <div class="stat-label">Sales Reps</div>
            <div class="stat-value">@empTotals.Count</div>
            <div class="small opacity-75 mt-1">contributing this year</div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card stat-card p-3">
            <div class="stat-label">Recent Orders</div>
            <div class="stat-value">@recentOrders.Count</div>
            <div class="small opacity-75 mt-1">last 20 orders</div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card stat-card p-3">
            <div class="stat-label">Products</div>
            <div class="stat-value">@topProducts.Count</div>
            <div class="small opacity-75 mt-1">in catalog (top 10)</div>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- Recent Orders -->
    <div class="col-12 col-xl-8">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center justify-content-between">
                <span><i class="bi bi-clock-history me-2"></i>Recent Orders</span>
                <a asp-controller="Orders" asp-action="Index" class="btn btn-sm btn-outline-primary no-print">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Order #</th>
                                <th>Date</th>
                                <th>Customer</th>
                                <th>Employee</th>
                                <th>Status</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in recentOrders)
                            {
                                var statusClass = "badge-status-" + (o.Status ?? "").ToLower();
                                <tr data-href="/Orders/Detail/@o.Id">
                                    <td><a asp-controller="Orders" asp-action="Detail" asp-route-id="@o.Id">#@o.Id</a></td>
                                    <td>@o.OrderDate?.ToString("MM/dd/yyyy")</td>
                                    <td>@(o.CustomerName ?? "-")</td>
                                    <td>@(o.EmployeeFullName ?? "-")</td>
                                    <td><span class="badge @statusClass">@o.StatusDisplay</span></td>
                                    <td class="text-end">@o.OrderTotal.ToString("C")</td>
                                </tr>
                            }
                            @if (!recentOrders.Any())
                            {
                                <tr><td colspan="6" class="text-center text-muted py-3">No orders found.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column -->
    <div class="col-12 col-xl-4">
        <!-- Sales by Rep -->
        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-person-lines-fill me-2"></i>Sales by Rep (YTD)</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr><th>Rep</th><th class="text-end">Total</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var e in empTotals)
                        {
                            <tr>
                                <td>@(e.Name ?? "-")</td>
                                <td class="text-end">@e.Total.ToString("C")</td>
                            </tr>
                        }
                        @if (!empTotals.Any())
                        {
                            <tr><td colspan="2" class="text-center text-muted py-2">No data.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Top Products -->
        <div class="card">
            <div class="card-header"><i class="bi bi-box-seam me-2"></i>Top Products</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr><th>Product</th><th class="text-end">Sold</th><th class="text-end">This Wk</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var p in topProducts)
                        {
                            <tr data-href="/Products/Detail/@p.Id">
                                <td><a asp-controller="Products" asp-action="Detail" asp-route-id="@p.Id">@p.ProductName</a></td>
                                <td class="text-end">@(p.TotalQuantitySold ?? 0)</td>
                                <td class="text-end @(p.SoldThisWeek > 0 ? "sold-this-week" : "")">@(p.SoldThisWeek ?? 0)</td>
                            </tr>
                        }
                        @if (!topProducts.Any())
                        {
                            <tr><td colspan="3" class="text-center text-muted py-2">No data.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

