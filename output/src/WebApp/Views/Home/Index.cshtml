@using WebApp.Models
@{
    ViewData["Title"] = "Dashboard";
    var ytd = ViewBag.Ytd as SalesYtdDto;
    var byEmployee = (ViewBag.ByEmployee as List<SalesByEmployeeDto>) ?? [];
    var recentOrders = (ViewBag.RecentOrders as List<OrderSummaryDto>) ?? [];
}

<div class="nw-page-header">
    <h1><i class="bi bi-speedometer2 me-2"></i>Dashboard</h1>
    <small class="text-muted">Northwind Traders &mdash; @DateTime.Today.Year</small>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="nw-stat-card">
            <div class="stat-label"><i class="bi bi-currency-dollar me-1"></i>YTD Revenue</div>
            <div class="stat-value">@(ytd != null ? "$" + ytd.TotalRevenue.ToString("N0") : "—")</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="nw-stat-card">
            <div class="stat-label"><i class="bi bi-cart3 me-1"></i>Recent Orders</div>
            <div class="stat-value">@recentOrders.Count</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="nw-stat-card">
            <div class="stat-label"><i class="bi bi-people me-1"></i>Salespeople</div>
            <div class="stat-value">@byEmployee.Count</div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="nw-stat-card">
            <div class="stat-label"><i class="bi bi-calendar-check me-1"></i>Year</div>
            <div class="stat-value">@(ytd?.Year ?? DateTime.Today.Year)</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-person-badge text-primary"></i>
                Revenue by Salesperson (YTD)
            </div>
            <div class="card-body p-0">
                @if (byEmployee.Count == 0)
                {
                    <div class="nw-empty"><i class="bi bi-inbox"></i>No data</div>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Salesperson</th>
                                <th class="text-end">Revenue</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in byEmployee.OrderByDescending(x => x.TotalRevenue))
                            {
                                <tr>
                                    <td>@e.EmployeeFullName</td>
                                    <td class="text-end fw-semibold">$@e.TotalRevenue.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center justify-content-between">
                <span><i class="bi bi-clock-history text-primary me-2"></i>Recent Orders</span>
                <a asp-controller="Orders" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body p-0">
                @if (recentOrders.Count == 0)
                {
                    <div class="nw-empty"><i class="bi bi-inbox"></i>No orders</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Date</th>
                                    <th>Customer</th>
                                    <th>Salesperson</th>
                                    <th>Status</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var o in recentOrders)
                                {
                                    <tr>
                                        <td><a asp-controller="Orders" asp-action="Detail" asp-route-id="@o.OrderId">#@o.OrderId</a></td>
                                        <td>@o.OrderDate?.ToString("MM/dd/yyyy")</td>
                                        <td>@o.CustomerName</td>
                                        <td>@o.EmployeeFullName</td>
                                        <td><span class="badge @GetStatusClass(o.StatusName)">@o.StatusName</span></td>
                                        <td class="text-end fw-semibold">$@o.OrderTotal.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@functions {
    string GetStatusClass(string? name) => (name ?? "").ToLower() switch
    {
        "new" => "status-new",
        "invoiced" => "status-invoiced",
        "shipped" => "status-shipped",
        "closed" => "status-closed",
        "cancelled" => "status-cancelled",
        _ => "bg-secondary"
    };
}
