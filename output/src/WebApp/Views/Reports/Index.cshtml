@* > Generated by booster-webdev | 2026-04-07 12:29:26 *@
@{
    ViewData["Title"] = "Reports";
    var defaultFrom = ViewBag.DefaultFrom as string;
    var defaultTo = ViewBag.DefaultTo as string;
}

<div class="nw-page-header">
    <h1><i class="bi bi-bar-chart me-2"></i>Reports</h1>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">Available Reports</div>
            <div class="card-body">
                <div class="list-group list-group-flush">
                    <a asp-action="SalesByProduct" asp-route-from="@defaultFrom" asp-route-to="@defaultTo"
                       class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3">
                        <i class="bi bi-bar-chart-line fs-4 text-primary"></i>
                        <div>
                            <div class="fw-semibold">Sales by Product (Monthly)</div>
                            <div class="text-muted small">Monthly revenue grouped by product with chart</div>
                        </div>
                        <i class="bi bi-chevron-right ms-auto text-muted"></i>
                    </a>
                    <a asp-action="SalesByProductQuarterly" asp-route-from="@defaultFrom" asp-route-to="@defaultTo"
                       class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3">
                        <i class="bi bi-bar-chart fs-4 text-primary"></i>
                        <div>
                            <div class="fw-semibold">Sales by Product (Quarterly)</div>
                            <div class="text-muted small">Quarterly revenue grouped by product</div>
                        </div>
                        <i class="bi bi-chevron-right ms-auto text-muted"></i>
                    </a>
                    <a asp-action="SalesByEmployee" asp-route-from="@defaultFrom" asp-route-to="@defaultTo"
                       class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3">
                        <i class="bi bi-person-lines-fill fs-4 text-primary"></i>
                        <div>
                            <div class="fw-semibold">Sales by Employee (Monthly)</div>
                            <div class="text-muted small">Monthly revenue grouped by salesperson</div>
                        </div>
                        <i class="bi bi-chevron-right ms-auto text-muted"></i>
                    </a>
                    <a asp-action="EmployeeEmailList"
                       class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3">
                        <i class="bi bi-envelope fs-4 text-primary"></i>
                        <div>
                            <div class="fw-semibold">Employee Email Directory</div>
                            <div class="text-muted small">Printable directory of employees with email addresses</div>
                        </div>
                        <i class="bi bi-chevron-right ms-auto text-muted"></i>
                    </a>
                    <a asp-action="EmployeePhoneList"
                       class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-3">
                        <i class="bi bi-telephone fs-4 text-primary"></i>
                        <div>
                            <div class="fw-semibold">Employee Phone Directory</div>
                            <div class="text-muted small">Printable directory of employees with phone numbers</div>
                        </div>
                        <i class="bi bi-chevron-right ms-auto text-muted"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">Date Range</div>
            <div class="card-body">
                <p class="text-muted small">Pre-fill the default date range for sales reports.</p>
                <div class="mb-3">
                    <label class="form-label">From</label>
                    <input type="date" id="fromDate" class="form-control" value="@defaultFrom" />
                </div>
                <div class="mb-3">
                    <label class="form-label">To</label>
                    <input type="date" id="toDate" class="form-control" value="@defaultTo" />
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Update report links with selected date range
        document.getElementById('fromDate').addEventListener('change', updateLinks);
        document.getElementById('toDate').addEventListener('change', updateLinks);
        function updateLinks() {
            const from = document.getElementById('fromDate').value;
            const to = document.getElementById('toDate').value;
            document.querySelectorAll('a[href*="SalesByProduct"], a[href*="SalesByEmployee"]').forEach(a => {
                const url = new URL(a.href, window.location.origin);
                url.searchParams.set('from', from);
                url.searchParams.set('to', to);
                a.href = url.toString();
            });
        }
    </script>
}
