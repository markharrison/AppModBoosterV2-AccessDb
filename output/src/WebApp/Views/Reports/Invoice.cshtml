@using WebApp.Models
@model InvoiceReport
@{
    ViewData["Title"] = $"Invoice #{Model?.OrderId}";
}

<nav aria-label="breadcrumb" class="mb-3 no-print">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Reports</a></li>
        <li class="breadcrumb-item active">Invoice #@Model?.OrderId</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-3 no-print">
    <h1 class="page-heading">Invoice #@Model?.OrderId</h1>
    <button onclick="window.print()" class="btn btn-outline-secondary no-print">
        <i class="bi bi-printer me-1"></i>Print
    </button>
</div>

<div class="invoice-wrapper mx-auto" style="max-width:760px">
    <!-- Header -->
    <div class="card mb-3">
        <div class="card-body">
            <div class="row">
                <div class="col-6">
                    <h4 class="fw-bold">Northwind Traders</h4>
                    <p class="text-muted mb-0 small">123 Commerce Street<br/>Redmond, WA 98052</p>
                </div>
                <div class="col-6 text-end">
                    <h5 class="fw-bold">INVOICE</h5>
                    <p class="mb-0 small">
                        <strong>Invoice #:</strong> @Model?.OrderId<br/>
                        <strong>Date:</strong> @Model?.OrderDate?.ToString("MMMM d, yyyy")<br/>
                        <strong>Status:</strong> @Model?.Status<br/>
                        <strong>Salesperson:</strong> @Model?.Employee?.FullName
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Bill To -->
    <div class="card mb-3">
        <div class="card-body">
            <h6 class="fw-semibold">Bill To:</h6>
            <p class="mb-0">
                <strong>@Model?.Customer?.CustomerName</strong><br/>
                @Model?.Customer?.Address<br/>
                @($"{Model?.Customer?.City}, {Model?.Customer?.State} {Model?.Customer?.Zip}")
            </p>
        </div>
    </div>

    <!-- Line Items -->
    <div class="card mb-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Code</th>
                            <th>Product</th>
                            <th class="text-end">Qty</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end">Extended</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in Model?.LineItems ?? new())
                        {
                            <tr>
                                <td>@line.ProductCode</td>
                                <td>@line.ProductName</td>
                                <td class="text-end">@line.Quantity</td>
                                <td class="text-end">@line.UnitPrice.ToString("C")</td>
                                <td class="text-end">@line.ExtendedPrice.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="4" class="text-end">Subtotal</td>
                            <td class="text-end">@Model?.Subtotal.ToString("C")</td>
                        </tr>
                        <tr>
                            <td colspan="4" class="text-end">Tax (@(((Model?.TaxRate ?? 0) * 100).ToString("F1"))%)</td>
                            <td class="text-end">@Model?.TaxAmount.ToString("C")</td>
                        </tr>
                        <tr class="fw-bold">
                            <td colspan="4" class="text-end">Total</td>
                            <td class="text-end">@Model?.Total.ToString("C")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>
