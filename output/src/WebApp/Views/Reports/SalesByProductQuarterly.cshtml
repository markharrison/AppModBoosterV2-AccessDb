@using WebApp.Models
@model List<SalesByProductQuarterlyDto>
@{
    ViewData["Title"] = "Sales by Product (Quarterly)";
    var from = ViewBag.From as string;
    var to = ViewBag.To as string;
    var products = Model.Select(x => x.ProductName).Distinct().ToList();
    var quarters = Model.Select(x => x.QuarterYear).Distinct().ToList();
}

<div class="nw-page-header">
    <h1><i class="bi bi-bar-chart me-2"></i>Sales by Product (Quarterly)</h1>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Reports</a>
</div>

<div class="nw-filter-bar">
    <form method="get" class="d-flex gap-3 align-items-end flex-wrap">
        <div>
            <label class="form-label">From</label>
            <input type="date" name="from" value="@from" class="form-control" />
        </div>
        <div>
            <label class="form-label">To</label>
            <input type="date" name="to" value="@to" class="form-control" />
        </div>
        <button type="submit" class="btn btn-outline-primary"><i class="bi bi-arrow-clockwise me-1"></i>Refresh</button>
    </form>
</div>

@if (Model.Count == 0)
{
    <div class="nw-empty"><i class="bi bi-inbox"></i>No data for selected range.</div>
}
else
{
    <div class="card mb-4">
        <div class="card-body">
            <canvas id="salesChart" height="100"></canvas>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Quarter</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.OrderBy(x => x.QuarterYear).ThenBy(x => x.ProductName))
                        {
                            <tr>
                                <td>@row.ProductName</td>
                                <td>@row.QuarterYear</td>
                                <td class="text-end">$@row.OrderTotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fw-bold">
                            <td colspan="2" class="text-end">Grand Total</td>
                            <td class="text-end">$@Model.Sum(x => x.OrderTotal).ToString("N2")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
}

@section Scripts {
    @if (Model.Count > 0)
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
        <script>
            const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(quarters));
            const productNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(products));
            const rawData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(x => new { x.ProductName, x.QuarterYear, x.OrderTotal })));
            const colors = ['#2e86c1','#e74c3c','#2ecc71','#f39c12','#9b59b6','#1abc9c','#e67e22'];

            const datasets = productNames.map((p, i) => ({
                label: p,
                data: labels.map(q => { const match = rawData.find(d => d.productName === p && d.quarterYear === q); return match ? match.orderTotal : 0; }),
                backgroundColor: colors[i % colors.length] + 'cc',
                borderColor: colors[i % colors.length],
                borderWidth: 1
            }));

            new Chart(document.getElementById('salesChart'), {
                type: 'bar',
                data: { labels, datasets },
                options: {
                    responsive: true,
                    plugins: { legend: { position: 'top' }, title: { display: true, text: 'Quarterly Sales by Product' } },
                    scales: { y: { beginAtZero: true, ticks: { callback: v => '$' + v.toLocaleString() } } }
                }
            });
        </script>
    }
}
