@* Generated by booster-webdev | 2026-04-06 *@
@using WebApp.Models
@model List<SalesByEmployee>
@{
    ViewData["Title"] = "Sales by Employee";
    int year = ViewBag.Year ?? DateTime.UtcNow.Year;
    var grouped = Model
        .GroupBy(r => r.EmployeeFullName ?? "Unknown")
        .OrderByDescending(g => g.Sum(r => r.TotalSales))
        .ToList();
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Reports</a></li>
        <li class="breadcrumb-item active">Sales by Employee</li>
    </ol>
</nav>

<div class="d-flex align-items-center justify-content-between mb-3 no-print">
    <h1 class="page-heading"><i class="bi bi-person-lines-fill me-2"></i>Sales by Employee</h1>
    <div class="d-flex gap-2 align-items-center">
        <form method="get" class="d-flex gap-2 align-items-center">
            <label class="form-label mb-0 small">Year:</label>
            <input type="number" name="year" value="@year" min="2000" max="2099"
                   class="form-control form-control-sm" style="width:90px" />
            <button type="submit" class="btn btn-sm btn-outline-primary">Go</button>
        </form>
        <button class="btn btn-sm btn-outline-secondary" onclick="window.print()">
            <i class="bi bi-printer me-1"></i>Print
        </button>
    </div>
</div>

<h5 class="text-muted mb-3">Year: @year</h5>

@if (!Model.Any())
{
    <div class="alert alert-info">No sales data found for @year.</div>
}
else
{
    @foreach (var grp in grouped)
    {
        var empTotal = grp.Sum(r => r.TotalSales);
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between">
                <span class="fw-semibold">@grp.Key</span>
                <span class="text-muted">YTD Total: <strong>@empTotal.ToString("C")</strong></span>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Period</th>
                            <th class="text-end">Sales</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in grp.OrderBy(r => r.MonthYearSort))
                        {
                            <tr>
                                <td>@row.MonthYear</td>
                                <td class="text-end">@row.TotalSales.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <th>Total</th>
                            <th class="text-end">@empTotal.ToString("C")</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }
}
