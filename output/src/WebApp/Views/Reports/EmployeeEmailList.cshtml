@* Generated by booster-webdev | 2026-04-06 *@
@using WebApp.Models
@model List<EmployeeEmailEntry>
@{
    ViewData["Title"] = "Employee Email Directory";
}

<nav aria-label="breadcrumb" class="mb-3 no-print">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Reports</a></li>
        <li class="breadcrumb-item active">Employee Email Directory</li>
    </ol>
</nav>

<div class="d-flex align-items-center justify-content-between mb-3 no-print">
    <h1 class="page-heading"><i class="bi bi-envelope-at me-2"></i>Employee Email Directory</h1>
    <button class="btn btn-sm btn-outline-secondary" onclick="window.print()">
        <i class="bi bi-printer me-1"></i>Print
    </button>
</div>

<div class="print-header d-none">
    <h2>Northwind Traders - Employee Email Directory</h2>
    <p>Printed: @DateTime.Now.ToString("MMMM d, yyyy")</p>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No employees found.</div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Email Address</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in Model.OrderBy(e => e.FullNameLNFN))
                    {
                        <tr>
                            <td>@emp.FullNameLNFN</td>
                            <td>
                                @if (!string.IsNullOrEmpty(emp.EmailAddress))
                                {
                                    <a href="mailto:@emp.EmailAddress">@emp.EmailAddress</a>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <p class="text-muted small mt-2">@Model.Count employee(s) listed.</p>
}
