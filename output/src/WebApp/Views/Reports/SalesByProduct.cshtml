@* Generated by booster-webdev | 2026-04-06 *@
@using WebApp.Models
@model List<SalesByProduct>
@{
    ViewData["Title"] = "Sales by Product";
    int year = ViewBag.Year ?? DateTime.UtcNow.Year;
    string groupBy = ViewBag.GroupBy ?? "month";
    var grouped = Model
        .GroupBy(r => r.ProductName ?? r.ProductCode ?? "Unknown")
        .OrderByDescending(g => g.Sum(r => r.TotalSales))
        .ToList();
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Reports</a></li>
        <li class="breadcrumb-item active">Sales by Product</li>
    </ol>
</nav>

<div class="d-flex align-items-center justify-content-between mb-3 no-print">
    <h1 class="page-heading"><i class="bi bi-box-seam me-2"></i>Sales by Product</h1>
    <div class="d-flex gap-2 align-items-center">
        <form method="get" class="d-flex gap-2 align-items-center">
            <label class="form-label mb-0 small">Year:</label>
            <input type="number" name="year" value="@year" min="2000" max="2099"
                   class="form-control form-control-sm" style="width:90px" />
            <label class="form-label mb-0 small ms-2">Group:</label>
            <select name="groupBy" class="form-select form-select-sm" style="width:120px">
                <option value="month" selected="@(groupBy == "month" ? "selected" : null)">Monthly</option>
                <option value="quarter" selected="@(groupBy == "quarter" ? "selected" : null)">Quarterly</option>
            </select>
            <button type="submit" class="btn btn-sm btn-outline-primary">Go</button>
        </form>
        <button class="btn btn-sm btn-outline-secondary" onclick="window.print()">
            <i class="bi bi-printer me-1"></i>Print
        </button>
    </div>
</div>

<h5 class="text-muted mb-3">Year: @year &mdash; Grouped by: @(groupBy == "quarter" ? "Quarter" : "Month")</h5>

@if (!Model.Any())
{
    <div class="alert alert-info">No sales data found for @year.</div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th>Period</th>
                        <th class="text-end">Sales</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var grp in grouped)
                    {
                        var rows = grp.OrderBy(r => r.PeriodSort).ToList();
                        var prodTotal = rows.Sum(r => r.TotalSales);
                        @foreach (var row in rows)
                        {
                            <tr>
                                <td>@(row.ProductName ?? row.ProductCode)</td>
                                <td>@row.Period</td>
                                <td class="text-end">@row.TotalSales.ToString("C")</td>
                            </tr>
                        }
                        <tr class="table-light fw-semibold">
                            <td colspan="2">@grp.Key Total</td>
                            <td class="text-end">@prodTotal.ToString("C")</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-dark">
                    <tr>
                        <th colspan="2">Grand Total</th>
                        <th class="text-end">@Model.Sum(r => r.TotalSales).ToString("C")</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
}
