@* Generated by booster-webdev | 2026-04-06 *@
@using WebApp.Models
@{
    ViewData["Title"] = "Admin";
    var settings = ViewBag.Settings as List<AdminSetting> ?? new();
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item active">Admin</li>
    </ol>
</nav>

<h1 class="page-heading mb-4"><i class="bi bi-gear me-2"></i>Admin</h1>

<div class="row g-4">
    <!-- System Settings -->
    <div class="col-12 col-lg-7">
        <div class="card">
            <div class="card-header"><i class="bi bi-sliders me-2"></i>System Settings</div>
            <div class="card-body p-0">
                @if (!settings.Any())
                {
                    <p class="text-muted px-3 py-2">No settings found.</p>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Setting</th>
                                <th>Value</th>
                                <th>Notes</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in settings)
                            {
                                <tr>
                                    <td class="align-middle fw-semibold">@s.SettingName</td>
                                    <td>
                                        <form asp-action="UpdateSetting" asp-route-id="@s.Id" method="post" class="d-flex gap-2">
                                            @Html.AntiForgeryToken()
                                            <input type="text" name="settingValue" value="@s.SettingValue"
                                                   class="form-control form-control-sm" style="max-width:160px" />
                                            <button type="submit" class="btn btn-sm btn-outline-primary">Save</button>
                                        </form>
                                    </td>
                                    <td class="text-muted small align-middle">@s.Notes</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <!-- Tools -->
    <div class="col-12 col-lg-5">
        <div class="card mb-3">
            <div class="card-header"><i class="bi bi-magic me-2"></i>Generate Test Orders</div>
            <div class="card-body">
                <p class="card-text text-muted small">Generate random orders using existing customers, employees, and products.</p>
                <form asp-action="GenerateOrders" method="post" class="d-flex gap-2 align-items-end">
                    @Html.AntiForgeryToken()
                    <div>
                        <label class="form-label small">Count</label>
                        <input type="number" name="count" value="10" min="1" max="500" class="form-control form-control-sm" style="width:90px" />
                    </div>
                    <button type="submit" class="btn btn-sm btn-success">Generate</button>
                </form>
            </div>
        </div>

        <div class="card border-danger">
            <div class="card-header text-danger"><i class="bi bi-trash me-2"></i>Delete Test Data</div>
            <div class="card-body">
                <p class="card-text text-muted small">Permanently delete all customers, employees, products, and orders that were created as test data (those not in the original seed). This cannot be undone.</p>
                <form asp-action="DeleteTestData" method="post"
                      onsubmit="return confirm('Delete all test data? This cannot be undone.')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-danger">Delete Test Data</button>
                </form>
            </div>
        </div>
    </div>
</div>
