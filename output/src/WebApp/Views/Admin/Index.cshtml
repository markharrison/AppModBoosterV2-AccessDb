@using WebApp.Models
@{
    ViewData["Title"] = "Admin";
    var settings = (ViewBag.Settings as List<SystemSettingDto>) ?? [];
}

<div class="nw-page-header">
    <h1><i class="bi bi-gear me-2"></i>Admin Panel</h1>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">System Settings</div>
            <div class="card-body p-0">
                @if (settings.Count == 0)
                {
                    <div class="nw-empty"><i class="bi bi-sliders"></i>No settings found.</div>
                }
                else
                {
                    <table class="table mb-0">
                        <thead><tr><th>Setting</th><th>Value</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var s in settings)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@s.SettingName</div>
                                        <div class="text-muted small">@s.Notes</div>
                                    </td>
                                    <td>
                                        <form asp-action="SaveSetting" asp-route-id="@s.SettingId" method="post" class="d-flex gap-1">
                                            @Html.AntiForgeryToken()
                                            <input type="text" name="settingValue" value="@s.SettingValue" class="form-control form-control-sm" style="width:100px" />
                                            <button type="submit" class="btn btn-sm btn-outline-primary">Save</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
            <div class="card-footer">
                <a asp-action="Settings" class="btn btn-sm btn-outline-secondary">Edit All Settings</a>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card mb-4">
            <div class="card-header"><i class="bi bi-magic me-2"></i>Generate Random Orders</div>
            <div class="card-body">
                <p class="text-muted small">Generate random test orders for development and demo purposes.</p>
                <form asp-action="GenerateOrders" method="post" class="d-flex gap-2 align-items-end">
                    @Html.AntiForgeryToken()
                    <div>
                        <label class="form-label">Number of Orders</label>
                        <input type="number" name="count" value="5" min="1" max="100" class="form-control" style="width:120px" />
                    </div>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-lightning me-1"></i>Generate</button>
                </form>
            </div>
        </div>

        <div class="card border-danger">
            <div class="card-header text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Danger Zone</div>
            <div class="card-body">
                <p class="text-muted small">Delete all test/seed data. This action cannot be undone.</p>
                <form asp-action="DeleteTestData" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger"
                            data-confirm="Delete ALL test data? This cannot be undone.">
                        <i class="bi bi-trash me-1"></i>Delete All Test Data
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
