@using WebApp.Models
@model List<SystemSettingDto>
@{
    ViewData["Title"] = "System Settings";
}

<div class="nw-page-header">
    <h1><i class="bi bi-sliders me-2"></i>System Settings</h1>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Admin</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Setting Name</th>
                    <th>Value</th>
                    <th>Notes</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td class="fw-semibold">@s.SettingName</td>
                        <td>
                            <form asp-action="SaveSetting" asp-route-id="@s.SettingId" method="post" class="d-flex gap-2">
                                @Html.AntiForgeryToken()
                                <input type="text" name="settingValue" value="@s.SettingValue" class="form-control form-control-sm" />
                                <button type="submit" class="btn btn-sm btn-primary">Save</button>
                            </form>
                        </td>
                        <td class="text-muted small">@s.Notes</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
