@using WebApp.Models
@model CustomerFormData
@{
    ViewData["Title"] = "New Customer";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Customers</a></li>
        <li class="breadcrumb-item active">New Customer</li>
    </ol>
</nav>

<h1 class="page-heading mb-4"><i class="bi bi-person-plus me-2"></i>New Customer</h1>

<div class="card" style="max-width:720px">
    <div class="card-body">
        <form asp-action="New" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <h6 class="fw-semibold mb-3">Company</h6>
            <div class="mb-3">
                <label class="form-label">Customer Name <span class="text-danger">*</span></label>
                <input asp-for="CustomerName" class="form-control" required />
            </div>

            <h6 class="fw-semibold mb-3 mt-4 border-top pt-3">Primary Contact</h6>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">First Name</label>
                    <input asp-for="PrimaryContactFirstName" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Last Name</label>
                    <input asp-for="PrimaryContactLastName" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Job Title</label>
                    <input asp-for="PrimaryContactJobTitle" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input asp-for="PrimaryContactEmailAddress" class="form-control" type="email" />
                </div>
            </div>

            <h6 class="fw-semibold mb-3 mt-4 border-top pt-3">Contact &amp; Address</h6>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Business Phone</label>
                    <input asp-for="BusinessPhone" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Website</label>
                    <input asp-for="Website" class="form-control" type="url" />
                </div>
                <div class="col-12">
                    <label class="form-label">Address</label>
                    <input asp-for="Address" class="form-control" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">City</label>
                    <input asp-for="City" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">State</label>
                    <input asp-for="State" class="form-control" maxlength="2" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Zip</label>
                    <input asp-for="Zip" class="form-control" />
                </div>
            </div>

            <div class="mb-3 mt-3">
                <label class="form-label">Notes</label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
