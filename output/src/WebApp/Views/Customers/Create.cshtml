@using WebApp.Models
@model CustomerRequest
@{
    ViewData["Title"] = "New Customer";
}

<div class="nw-page-header">
    <h1><i class="bi bi-person-plus me-2"></i>New Customer</h1>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label">Customer Name</label>
                    <input asp-for="CustomerName" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Business Phone</label>
                    <input asp-for="BusinessPhone" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Contact First Name</label>
                    <input asp-for="PrimaryContactFirstName" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Contact Last Name</label>
                    <input asp-for="PrimaryContactLastName" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Contact Job Title</label>
                    <input asp-for="PrimaryContactJobTitle" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input asp-for="PrimaryContactEmailAddress" class="form-control" type="email" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Website</label>
                    <input asp-for="Website" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label">Address</label>
                    <input asp-for="Address" class="form-control" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">City</label>
                    <input asp-for="City" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">State</label>
                    <input asp-for="State" class="form-control" maxlength="2" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Zip</label>
                    <input asp-for="Zip" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save Customer</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
