@using WebApp.Models
@model PagedResult<CustomerListItem>?
@{
    ViewData["Title"] = "Customers";
    var search = ViewBag.Search as string;
    var activeOnly = (bool)(ViewBag.ActiveOnly ?? false);
    var currentPage = Model?.Page ?? 1;
    var totalPages = Model?.TotalPages ?? 1;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item active">Customers</li>
    </ol>
</nav>

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="page-heading"><i class="bi bi-people me-2"></i>Customers</h1>
    <a asp-action="New" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>New Customer</a>
</div>

<!-- Filter bar -->
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-auto flex-grow-1">
                <input type="text" name="search" value="@search" class="form-control" placeholder="Search name, city, contact..." />
            </div>
            <div class="col-auto">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="activeOnly" value="true" @(activeOnly ? "checked" : "") id="activeOnlyChk" />
                    <label class="form-check-label" for="activeOnlyChk">Active only</label>
                </div>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-outline-primary">Search</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-1">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Primary Contact</th>
                        <th>Phone</th>
                        <th>City</th>
                        <th>State</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model?.Items ?? new())
                    {
                        <tr data-href="/Customers/Detail/@c.Id">
                            <td><a asp-action="Detail" asp-route-id="@c.Id">@c.CustomerName</a></td>
                            <td>@c.PrimaryContactFullName</td>
                            <td>@c.BusinessPhone</td>
                            <td>@c.City</td>
                            <td>@c.State</td>
                        </tr>
                    }
                    @if (!(Model?.Items?.Any() ?? false))
                    {
                        <tr><td colspan="5" class="text-center text-muted py-3">No customers found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (var i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-search="@search" asp-route-activeOnly="@activeOnly" asp-route-page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}
