@using WebApp.Models
@model CustomerDto
@{
    ViewData["Title"] = "Customer - " + Model.CustomerName;
    var orders = (ViewBag.Orders as List<OrderSummaryDto>) ?? [];
    var products = (ViewBag.Products as List<CustomerProductDto>) ?? [];
}

<div class="nw-page-header">
    <h1><i class="bi bi-person me-2"></i>@Model.CustomerName</h1>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
        <form asp-action="Delete" asp-route-id="@Model.CustomerId" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger"
                    data-confirm="Delete this customer? This cannot be undone.">
                <i class="bi bi-trash me-1"></i>Delete
            </button>
        </form>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">Customer Details</div>
            <div class="card-body">
                <form asp-action="Detail" asp-route-id="@Model.CustomerId" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Customer Name</label>
                            <input class="form-control" name="CustomerName" value="@Model.CustomerName" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Business Phone</label>
                            <input class="form-control" name="BusinessPhone" value="@Model.BusinessPhone" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Website</label>
                            <input class="form-control" name="Website" value="@Model.Website" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Contact First Name</label>
                            <input class="form-control" name="PrimaryContactFirstName" value="@Model.PrimaryContactFirstName" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Contact Last Name</label>
                            <input class="form-control" name="PrimaryContactLastName" value="@Model.PrimaryContactLastName" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Contact Job Title</label>
                            <input class="form-control" name="PrimaryContactJobTitle" value="@Model.PrimaryContactJobTitle" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input class="form-control" name="PrimaryContactEmailAddress" value="@Model.PrimaryContactEmailAddress" type="email" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Address</label>
                            <input class="form-control" name="Address" value="@Model.Address" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">City</label>
                            <input class="form-control" name="City" value="@Model.City" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">State</label>
                            <input class="form-control" name="State" value="@Model.State" maxlength="2" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Zip</label>
                            <input class="form-control" name="Zip" value="@Model.Zip" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Notes</label>
                            <textarea class="form-control" name="Notes" rows="3">@Model.Notes</textarea>
                        </div>
                    </div>
                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card">
            <div class="card-header p-0 border-0">
                <ul class="nav nav-tabs px-3 pt-2" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link active" data-bs-toggle="tab" href="#tabOrders">
                            <i class="bi bi-cart3 me-1"></i>Orders (@orders.Count)
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#tabProducts">
                            <i class="bi bi-box-seam me-1"></i>Products (@products.Count)
                        </a>
                    </li>
                </ul>
            </div>
            <div class="card-body p-0">
                <div class="tab-content">
                    <div class="tab-pane fade show active" id="tabOrders">
                        @if (orders.Count == 0)
                        {
                            <div class="nw-empty"><i class="bi bi-inbox"></i>No orders</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead><tr><th>Date</th><th>Salesperson</th><th>Status</th><th class="text-end">Total</th></tr></thead>
                                    <tbody>
                                        @foreach (var o in orders)
                                        {
                                            <tr>
                                                <td><a asp-controller="Orders" asp-action="Detail" asp-route-id="@o.OrderId">@o.OrderDate?.ToString("MM/dd/yyyy")</a></td>
                                                <td>@o.EmployeeFullName</td>
                                                <td><span class="badge bg-secondary">@o.StatusName</span></td>
                                                <td class="text-end">$@o.OrderTotal.ToString("N2")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                    <div class="tab-pane fade" id="tabProducts">
                        @if (products.Count == 0)
                        {
                            <div class="nw-empty"><i class="bi bi-inbox"></i>No products</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead><tr><th>Product</th><th class="text-end">Qty</th><th class="text-end">Orders</th></tr></thead>
                                    <tbody>
                                        @foreach (var p in products)
                                        {
                                            <tr>
                                                <td>@p.ProductName</td>
                                                <td class="text-end">@p.TotalQuantity</td>
                                                <td class="text-end">@p.OrderCount</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
