@using WebApp.Models
@model CustomerDetail
@{
    ViewData["Title"] = Model?.CustomerName ?? "Customer";
    var orders = ViewBag.Orders as List<OrderListItem> ?? new();
    var products = ViewBag.Products as List<CustomerProductSummary> ?? new();
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Customers</a></li>
        <li class="breadcrumb-item active">@Model?.CustomerName</li>
    </ol>
</nav>

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="page-heading"><i class="bi bi-person me-2"></i>@Model?.CustomerName</h1>
</div>

<div class="row g-3">
    <div class="col-12 col-lg-7">
        <div class="card h-100">
            <div class="card-header">Customer Details</div>
            <div class="card-body">
                <form asp-action="Detail" asp-route-id="@Model?.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="mb-3">
                        <label class="form-label">Customer Name <span class="text-danger">*</span></label>
                        <input name="CustomerName" value="@Model?.CustomerName" class="form-control" required />
                    </div>
                    <div class="row g-2">
                        <div class="col-md-6 mb-2">
                            <label class="form-label">First Name</label>
                            <input name="PrimaryContactFirstName" value="@Model?.PrimaryContactFirstName" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Last Name</label>
                            <input name="PrimaryContactLastName" value="@Model?.PrimaryContactLastName" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Job Title</label>
                            <input name="PrimaryContactJobTitle" value="@Model?.PrimaryContactJobTitle" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Email</label>
                            <input name="PrimaryContactEmailAddress" value="@Model?.PrimaryContactEmailAddress" class="form-control" type="email" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Business Phone</label>
                            <input name="BusinessPhone" value="@Model?.BusinessPhone" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Website</label>
                            <input name="Website" value="@Model?.Website" class="form-control" />
                        </div>
                        <div class="col-12 mb-2">
                            <label class="form-label">Address</label>
                            <input name="Address" value="@Model?.Address" class="form-control" />
                        </div>
                        <div class="col-md-5 mb-2">
                            <label class="form-label">City</label>
                            <input name="City" value="@Model?.City" class="form-control" />
                        </div>
                        <div class="col-md-3 mb-2">
                            <label class="form-label">State</label>
                            <input name="State" value="@Model?.State" class="form-control" maxlength="2" />
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label">Zip</label>
                            <input name="Zip" value="@Model?.Zip" class="form-control" />
                        </div>
                        <div class="col-12 mb-2">
                            <label class="form-label">Notes</label>
                            <textarea name="Notes" class="form-control" rows="3">@Model?.Notes</textarea>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">Save</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
                    </div>
                </form>

                <form asp-action="Delete" asp-route-id="@Model?.Id" method="post" class="mt-2"
                      onsubmit="return confirm('Delete this customer?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete Customer</button>
                </form>

                @if (Model?.ModifiedOn.HasValue == true)
                {
                    <p class="text-muted small mt-3 mb-0">Last modified: @Model.ModifiedOn?.ToString("g")</p>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-5">
        <!-- Tabs: Orders / Products -->
        <div class="card">
            <div class="card-header">
                <ul class="nav nav-tabs card-header-tabs" id="custTabs">
                    <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#ordersTab">Orders (@orders.Count)</button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#productsTab">Products (@products.Count)</button></li>
                </ul>
            </div>
            <div class="card-body p-0">
                <div class="tab-content">
                    <div class="tab-pane fade show active" id="ordersTab">
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr><th>#</th><th>Date</th><th>Employee</th><th>Status</th><th class="text-end">Total</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var o in orders)
                                    {
                                        var sc = "badge-status-" + (o.Status ?? "").ToLower();
                                        <tr data-href="/Orders/Detail/@o.Id">
                                            <td><a asp-controller="Orders" asp-action="Detail" asp-route-id="@o.Id">#@o.Id</a></td>
                                            <td>@o.OrderDate?.ToString("MM/dd/yy")</td>
                                            <td>@o.EmployeeFullName</td>
                                            <td><span class="badge @sc">@o.StatusDisplay</span></td>
                                            <td class="text-end">@o.OrderTotal.ToString("C")</td>
                                        </tr>
                                    }
                                    @if (!orders.Any()){ <tr><td colspan="5" class="text-center text-muted py-2">No orders.</td></tr> }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="tab-pane fade" id="productsTab">
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr><th>Product</th><th class="text-end">Qty</th><th class="text-end">Orders</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in products)
                                    {
                                        <tr>
                                            <td><a asp-controller="Products" asp-action="Detail" asp-route-id="@p.ProductId">@p.ProductName</a></td>
                                            <td class="text-end">@p.TotalQuantity</td>
                                            <td class="text-end">@p.OrderCount</td>
                                        </tr>
                                    }
                                    @if (!products.Any()){ <tr><td colspan="3" class="text-center text-muted py-2">No products.</td></tr> }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
