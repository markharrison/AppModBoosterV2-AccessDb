@using WebApp.Models
@model ProductDto
@{
    ViewData["Title"] = "Product - " + Model.ProductName;
    var orders = (ViewBag.Orders as List<ProductOrderDto>) ?? [];
}

<div class="nw-page-header">
    <h1><i class="bi bi-box-seam me-2"></i>@Model.ProductName</h1>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
        <form asp-action="Delete" asp-route-id="@Model.ProductId" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger"
                    data-confirm="Delete this product?">
                <i class="bi bi-trash me-1"></i>Delete
            </button>
        </form>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">Product Details</div>
            <div class="card-body">
                <form asp-action="Detail" asp-route-id="@Model.ProductId" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label">Product Code</label>
                            <input class="form-control" name="ProductCode" value="@Model.ProductCode" />
                        </div>
                        <div class="col-md-7">
                            <label class="form-label">Product Name</label>
                            <input class="form-control" name="ProductName" value="@Model.ProductName" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" name="ProductDescription" rows="3">@Model.ProductDescription</textarea>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Unit Price</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input class="form-control" name="UnitPrice" value="@Model.UnitPrice" type="number" step="0.01" min="0" />
                            </div>
                        </div>
                    </div>
                    <div class="mt-4 d-flex gap-3">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card">
            <div class="card-header"><i class="bi bi-cart3 me-2"></i>Orders (@orders.Count)</div>
            <div class="card-body p-0">
                @if (orders.Count == 0)
                {
                    <div class="nw-empty"><i class="bi bi-inbox"></i>No orders</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead><tr><th>Date</th><th>Customer</th><th class="text-end">Qty</th><th class="text-end">Unit Price</th><th class="text-end">Extended</th></tr></thead>
                            <tbody>
                                @foreach (var o in orders)
                                {
                                    <tr>
                                        <td><a asp-controller="Orders" asp-action="Detail" asp-route-id="@o.OrderId">@o.OrderDate?.ToString("MM/dd/yyyy")</a></td>
                                        <td>@o.CustomerName</td>
                                        <td class="text-end">@o.Quantity</td>
                                        <td class="text-end">$@o.UnitPrice?.ToString("N2")</td>
                                        <td class="text-end">$@o.ExtendedPrice.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
