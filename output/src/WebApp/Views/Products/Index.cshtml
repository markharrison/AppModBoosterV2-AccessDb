@using WebApp.Models
@model PagedResult<ProductListItem>?
@{
    ViewData["Title"] = "Products";
    var search = ViewBag.Search as string;
    var currentPage = Model?.Page ?? 1;
    var totalPages = Model?.TotalPages ?? 1;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item active">Products</li>
    </ol>
</nav>

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="page-heading"><i class="bi bi-box me-2"></i>Products</h1>
    <a asp-action="New" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>New Product</a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="search" value="@search" class="form-control" placeholder="Search code or name..." />
            <button type="submit" class="btn btn-outline-primary">Search</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th class="text-end">Unit Price</th>
                        <th class="text-end">Qty Sold</th>
                        <th class="text-end">This Week</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model?.Items ?? new())
                    {
                        <tr data-href="/Products/Detail/@p.Id">
                            <td><a asp-action="Detail" asp-route-id="@p.Id">@p.ProductCode</a></td>
                            <td>@p.ProductName</td>
                            <td class="text-end">@p.UnitPrice.ToString("C")</td>
                            <td class="text-end">@(p.TotalQuantitySold ?? 0)</td>
                            <td class="text-end @(p.SoldThisWeek > 0 ? "sold-this-week" : "")">@(p.SoldThisWeek ?? 0)</td>
                        </tr>
                    }
                    @if (!(Model?.Items?.Any() ?? false))
                    {
                        <tr><td colspan="5" class="text-center text-muted py-3">No products found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (var i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-search="@search" asp-route-page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}
