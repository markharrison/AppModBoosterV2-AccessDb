@using WebApp.Models
@model ProductRequest
@{
    ViewData["Title"] = "New Product";
}

<div class="nw-page-header">
    <h1><i class="bi bi-plus-circle me-2"></i>New Product</h1>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="card" style="max-width:600px">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Product Code</label>
                    <input asp-for="ProductCode" class="form-control" />
                </div>
                <div class="col-md-8">
                    <label class="form-label">Product Name</label>
                    <input asp-for="ProductName" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label">Description</label>
                    <textarea asp-for="ProductDescription" class="form-control" rows="3"></textarea>
                </div>
                <div class="col-md-5">
                    <label class="form-label">Unit Price</label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" min="0" />
                    </div>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save Product</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
