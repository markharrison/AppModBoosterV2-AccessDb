<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <style>
        body { font-family: 'Segoe UI', system-ui, sans-serif; background: white; color: #212529; }
        .nw-invoice { max-width: 800px; margin: 2rem auto; padding: 2rem; background: white; }
        .invoice-header { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 3px solid #1a5276; padding-bottom: 1.5rem; margin-bottom: 1.5rem; }
        .company-name { font-size: 1.8rem; font-weight: 800; color: #1a5276; margin: 0; }
        .company-tagline { color: #6c757d; font-size: 1rem; }
        .invoice-meta table { border-collapse: collapse; font-size: 0.9rem; }
        .invoice-meta th { text-align: right; padding-right: 0.75rem; color: #6c757d; font-weight: 600; white-space: nowrap; }
        .invoice-meta td { padding: 0.15rem 0; }
        .bill-to { margin-bottom: 1.5rem; font-size: 0.95rem; line-height: 1.8; }
        .invoice-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
        .invoice-table thead th { background: #f0f4f8; padding: 0.5rem 0.75rem; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.04em; color: #6c757d; }
        .invoice-table tbody td { padding: 0.5rem 0.75rem; border-bottom: 1px solid #dee2e6; }
        .invoice-table tfoot td { padding: 0.75rem; font-size: 1rem; border-top: 2px solid #1a5276; }
        .text-end { text-align: right; }
        .invoice-footer { padding-top: 1rem; border-top: 1px solid #dee2e6; }
        .btn { border-radius: 6px; font-weight: 500; padding: 0.4rem 1rem; }
        .btn-outline-primary { color: #1a5276; border-color: #1a5276; }
        @@media print {
            .nw-no-print { display: none !important; }
            body { margin: 0; }
            .nw-invoice { margin: 0; max-width: 100%; box-shadow: none; }
        }
    </style>
</head>
<body>
    @RenderBody()
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"></script>
</body>
</html>
