@using WebApp.Models
@model List<EmployeeDto>
@{
    ViewData["Title"] = "Employees";
}

<div class="nw-page-header">
    <h1><i class="bi bi-person-badge me-2"></i>Employees</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>New Employee</a>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Count == 0)
        {
            <div class="nw-empty"><i class="bi bi-person-badge"></i>No employees found.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Job Title</th>
                            <th>Email</th>
                            <th>Primary Phone</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in Model)
                        {
                            <tr>
                                <td><a asp-action="Detail" asp-route-id="@e.EmployeeId">@e.FullNameFNLN</a></td>
                                <td>@e.JobTitle</td>
                                <td>@e.EmailAddress</td>
                                <td>@e.PrimaryPhone</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
