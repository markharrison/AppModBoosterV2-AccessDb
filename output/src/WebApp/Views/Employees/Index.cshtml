@using WebApp.Models
@model PagedResult<EmployeeListItem>?
@{
    ViewData["Title"] = "Employees";
    var search = ViewBag.Search as string;
    var currentPage = Model?.Page ?? 1;
    var totalPages = Model?.TotalPages ?? 1;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item active">Employees</li>
    </ol>
</nav>

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="page-heading"><i class="bi bi-person-badge me-2"></i>Employees</h1>
    <a asp-action="New" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>New Employee</a>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="search" value="@search" class="form-control" placeholder="Search name or email..." />
            <button type="submit" class="btn btn-outline-primary">Search</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Job Title</th>
                        <th>Email</th>
                        <th>Primary Phone</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var e in Model?.Items ?? new())
                    {
                        <tr data-href="/Employees/Detail/@e.Id">
                            <td><a asp-action="Detail" asp-route-id="@e.Id">@e.FullNameLNFN</a></td>
                            <td>@e.JobTitle</td>
                            <td>@e.EmailAddress</td>
                            <td>@e.PrimaryPhone</td>
                        </tr>
                    }
                    @if (!(Model?.Items?.Any() ?? false))
                    {
                        <tr><td colspan="4" class="text-center text-muted py-3">No employees found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (var i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-search="@search" asp-route-page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}
