@using WebApp.Models
@model EmployeeFormData
@{
    ViewData["Title"] = "New Employee";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Employees</a></li>
        <li class="breadcrumb-item active">New Employee</li>
    </ol>
</nav>

<h1 class="page-heading mb-4"><i class="bi bi-person-plus me-2"></i>New Employee</h1>

<div class="card" style="max-width:600px">
    <div class="card-body">
        <form asp-action="New" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">
                <div class="col-md-2">
                    <label class="form-label">Title</label>
                    <input asp-for="Title" class="form-control" placeholder="Mr." />
                </div>
                <div class="col-md-5">
                    <label class="form-label">First Name</label>
                    <input asp-for="FirstName" class="form-control" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">Last Name</label>
                    <input asp-for="LastName" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Job Title</label>
                    <input asp-for="JobTitle" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Email Address</label>
                    <input asp-for="EmailAddress" class="form-control" type="email" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Primary Phone</label>
                    <input asp-for="PrimaryPhone" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Secondary Phone</label>
                    <input asp-for="SecondaryPhone" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label">Windows Username <span class="text-muted">(optional)</span></label>
                    <input asp-for="WindowsUserName" class="form-control" />
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
