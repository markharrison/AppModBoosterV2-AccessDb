@using WebApp.Models
@model EmployeeRequest
@{
    ViewData["Title"] = "New Employee";
}

<div class="nw-page-header">
    <h1><i class="bi bi-person-plus me-2"></i>New Employee</h1>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="card" style="max-width:640px">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-2">
                    <label class="form-label">Title</label>
                    <input asp-for="Title" class="form-control" placeholder="Mr/Ms" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">First Name</label>
                    <input asp-for="FirstName" class="form-control" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">Last Name</label>
                    <input asp-for="LastName" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Job Title</label>
                    <input asp-for="JobTitle" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input asp-for="EmailAddress" class="form-control" type="email" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Primary Phone</label>
                    <input asp-for="PrimaryPhone" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Secondary Phone</label>
                    <input asp-for="SecondaryPhone" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label">Windows Username</label>
                    <input asp-for="WindowsUserName" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                </div>
            </div>
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save Employee</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
