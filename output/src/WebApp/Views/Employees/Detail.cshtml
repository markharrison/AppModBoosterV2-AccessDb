@using WebApp.Models
@model EmployeeDto
@{
    ViewData["Title"] = "Employee - " + Model.FullNameFNLN;
    var orders = (ViewBag.Orders as List<OrderSummaryDto>) ?? [];
}

<div class="nw-page-header">
    <h1><i class="bi bi-person-badge me-2"></i>@Model.FullNameFNLN</h1>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
        <form asp-action="Delete" asp-route-id="@Model.EmployeeId" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger"
                    data-confirm="Delete this employee?">
                <i class="bi bi-trash me-1"></i>Delete
            </button>
        </form>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">Employee Details</div>
            <div class="card-body">
                <form asp-action="Detail" asp-route-id="@Model.EmployeeId" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-2">
                            <label class="form-label">Title</label>
                            <input class="form-control" name="Title" value="@Model.Title" placeholder="Mr/Ms" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">First Name</label>
                            <input class="form-control" name="FirstName" value="@Model.FirstName" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Last Name</label>
                            <input class="form-control" name="LastName" value="@Model.LastName" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Job Title</label>
                            <input class="form-control" name="JobTitle" value="@Model.JobTitle" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Email</label>
                            <input class="form-control" name="EmailAddress" value="@Model.EmailAddress" type="email" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Primary Phone</label>
                            <input class="form-control" name="PrimaryPhone" value="@Model.PrimaryPhone" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Secondary Phone</label>
                            <input class="form-control" name="SecondaryPhone" value="@Model.SecondaryPhone" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Windows Username</label>
                            <input class="form-control" name="WindowsUserName" value="@Model.WindowsUserName" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Notes</label>
                            <textarea class="form-control" name="Notes" rows="3">@Model.Notes</textarea>
                        </div>
                    </div>
                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card">
            <div class="card-header"><i class="bi bi-cart3 me-2"></i>Assigned Orders (@orders.Count)</div>
            <div class="card-body p-0">
                @if (orders.Count == 0)
                {
                    <div class="nw-empty"><i class="bi bi-inbox"></i>No orders</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead><tr><th>Date</th><th>Customer</th><th>Status</th><th class="text-end">Total</th></tr></thead>
                            <tbody>
                                @foreach (var o in orders)
                                {
                                    <tr>
                                        <td><a asp-controller="Orders" asp-action="Detail" asp-route-id="@o.OrderId">@o.OrderDate?.ToString("MM/dd/yyyy")</a></td>
                                        <td>@o.CustomerName</td>
                                        <td><span class="badge bg-secondary">@o.StatusName</span></td>
                                        <td class="text-end">$@o.OrderTotal.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
