@using WebApp.Models
@model EmployeeDetail
@{
    ViewData["Title"] = Model?.FullNameFNLN ?? "Employee";
    var orders = ViewBag.Orders as List<OrderListItem> ?? new();
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Employees</a></li>
        <li class="breadcrumb-item active">@Model?.FullNameFNLN</li>
    </ol>
</nav>

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="page-heading"><i class="bi bi-person-badge me-2"></i>@Model?.FullNameFNLN</h1>
</div>

<div class="row g-3">
    <div class="col-12 col-lg-5">
        <div class="card">
            <div class="card-header">Employee Details</div>
            <div class="card-body">
                <form asp-action="Detail" asp-route-id="@Model?.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-2">
                        <div class="col-md-3 mb-2">
                            <label class="form-label">Title</label>
                            <input name="Title" value="@Model?.Title" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label">First Name</label>
                            <input name="FirstName" value="@Model?.FirstName" class="form-control" />
                        </div>
                        <div class="col-md-5 mb-2">
                            <label class="form-label">Last Name</label>
                            <input name="LastName" value="@Model?.LastName" class="form-control" />
                        </div>
                        <div class="col-12 mb-2">
                            <label class="form-label">Job Title</label>
                            <input name="JobTitle" value="@Model?.JobTitle" class="form-control" />
                        </div>
                        <div class="col-12 mb-2">
                            <label class="form-label">Email</label>
                            <input name="EmailAddress" value="@Model?.EmailAddress" class="form-control" type="email" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Primary Phone</label>
                            <input name="PrimaryPhone" value="@Model?.PrimaryPhone" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Secondary Phone</label>
                            <input name="SecondaryPhone" value="@Model?.SecondaryPhone" class="form-control" />
                        </div>
                        <div class="col-12 mb-2">
                            <label class="form-label">Notes</label>
                            <textarea name="Notes" class="form-control" rows="3">@Model?.Notes</textarea>
                        </div>
                        <div class="col-12 mb-2">
                            <label class="form-label">Windows Username</label>
                            <input name="WindowsUserName" value="@Model?.WindowsUserName" class="form-control" />
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">Save</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
                    </div>
                </form>

                <form asp-action="Delete" asp-route-id="@Model?.Id" method="post" class="mt-2"
                      onsubmit="return confirm('Delete this employee?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete Employee</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-7">
        <div class="card">
            <div class="card-header"><i class="bi bi-cart3 me-1"></i>Assigned Orders (@orders.Count)</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>#</th><th>Date</th><th>Customer</th><th>Status</th><th class="text-end">Total</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var o in orders)
                            {
                                var sc = "badge-status-" + (o.Status ?? "").ToLower();
                                <tr data-href="/Orders/Detail/@o.Id">
                                    <td><a asp-controller="Orders" asp-action="Detail" asp-route-id="@o.Id">#@o.Id</a></td>
                                    <td>@o.OrderDate?.ToString("MM/dd/yy")</td>
                                    <td>@o.CustomerName</td>
                                    <td><span class="badge @sc">@o.StatusDisplay</span></td>
                                    <td class="text-end">@o.OrderTotal.ToString("C")</td>
                                </tr>
                            }
                            @if (!orders.Any()){ <tr><td colspan="5" class="text-center text-muted py-2">No orders.</td></tr> }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
